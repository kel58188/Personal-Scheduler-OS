    {
      "parameters": {
        "jsCode": "const rawTargetName =\n  $node[\"Parse Reschedule Request\"]?.json?.output?.task_name || \"\";\n\nconst allTasks = $json.data?.items || [];\n\nfunction normalizeTaskName(text) {\n  return String(text)\n    .trim()\n    .replace(/没完成|还没完成|今天做不完|做不完|没做完|未完成|完成不了/g, \"\")\n    .trim();\n}\n\nconst normalizedTargetName = normalizeTaskName(rawTargetName);\n\nlet matched = null;\n\nfor (const item of allTasks) {\n  const fields = item.fields || {};\n  const nameField = String(fields.task_name?.[0]?.text || \"\").trim();\n\n  if (!nameField) {\n    continue;\n  }\n\n  const normalizedNameField = normalizeTaskName(nameField);\n\n  if (\n    normalizedNameField === normalizedTargetName ||\n    normalizedTargetName.includes(normalizedNameField) ||\n    normalizedNameField.includes(normalizedTargetName)\n  ) {\n    matched = {\n      record_id: item.record_id,\n      task_id: fields.task_id?.[0]?.text || \"\",\n      task_name: nameField,\n      status: fields.status || \"\"\n    };\n    break;\n  }\n}\n\nif (!matched) {\n  throw new Error(\"没有找到匹配的任务: \" + normalizedTargetName);\n}\n\nreturn [{ json: matched }];"
      },
